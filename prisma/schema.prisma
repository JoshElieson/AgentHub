// Nuclexa — Prisma schema (PostgreSQL)
// ---------------------------------------------------------------------------
// Prisma manages ONLY the auth + social-graph tables here (NextAuth/Auth.js
// identity and the follow system). The marketplace itself — skills, MCP
// servers, collections, and all engagement (stars / saves / installs /
// ratings) — lives in snake_case tables managed directly via the Supabase JS
// client (see supabase/*.sql and src/lib/marketplace-data.ts); those are NOT
// modeled here.
//
// The legacy `AgentPackage` relational marketplace model that used to live in
// this file was never wired to the running app (it stayed empty) and has been
// removed; the in-repo mock catalog in src/lib/data powers the agent/org/
// collection demo pages instead.
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Identity --------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  // `username` is null immediately after an OAuth sign-in (the NextAuth adapter
  // doesn't set it); it's generated in the `createUser` event. `name` is
  // nullable for the same reason (some providers omit it).
  username      String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  // OAuth profile picture URL. Avatars fall back to an `avatarColor` gradient.
  image         String?
  bio           String?
  avatarColor   String?
  website       String?
  github        String?
  twitter       String?
  location      String?
  isVerified    Boolean   @default(false)
  followers     Int       @default(0)
  following     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth / Auth.js
  accounts Account[]
  sessions Session[]

  // Social graph
  followedBy Follow[] @relation("Following") // people who follow this user
  follows    Follow[] @relation("Follower")  // people this user follows
}

// --- NextAuth (Auth.js) tables ---------------------------------------------
// Standard shapes required by @next-auth/prisma-adapter. See:
// https://authjs.dev/reference/adapter/prisma

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Social graph ----------------------------------------------------------

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}
