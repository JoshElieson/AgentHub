# ----------------------------------------------------------------------------
# AgentDock environment configuration
# Copy to `.env` (or `.env.local`). The app runs WITHOUT any of these set —
# it falls back to mock auth / dev mode and seeded mock data.
# ----------------------------------------------------------------------------

# --- Auth (Auth.js / NextAuth) ---------------------------------------------
# Leave blank to run in mock-auth dev mode. Providers only activate when the
# corresponding id + secret are present.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

GITHUB_ID=""
GITHUB_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Database (optional — schema is PostgreSQL-ready, dev falls back) -------
# Production (PostgreSQL):
#   DATABASE_URL="postgresql://user:password@localhost:5432/agentdock?schema=public"
# Local dev (SQLite) — switch prisma/schema.prisma datasource provider to "sqlite":
#   DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://user:password@localhost:5432/agentdock?schema=public"
