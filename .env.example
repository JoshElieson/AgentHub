# ----------------------------------------------------------------------------
# Nuclexa environment configuration
# Copy to `.env` (or `.env.local`). The app runs WITHOUT any of these set —
# it falls back to mock auth / dev mode and seeded mock data.
# ----------------------------------------------------------------------------

# --- Auth (Auth.js / NextAuth) ---------------------------------------------
# Leave blank to run in mock-auth dev mode. Providers only activate when the
# corresponding id + secret are present.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

GITHUB_ID=""
GITHUB_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Database (optional — schema is PostgreSQL-ready, dev falls back) -------
# Production (PostgreSQL):
#   DATABASE_URL="postgresql://user:password@localhost:5432/nuclexa?schema=public"
# Local dev (SQLite) — switch prisma/schema.prisma datasource provider to "sqlite":
#   DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://user:password@localhost:5432/nuclexa?schema=public"

# --- Semantic Search (optional — falls back to text filtering) ---------------
# Google AI API key for gemini-embedding-001 embeddings (pgvector semantic search).
# Get one at https://aistudio.google.com/apikey
# If left blank, search falls back to client-side text filtering.
GOOGLE_AI_API_KEY=""
